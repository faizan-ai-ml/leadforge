# Environment variables configuration template
# Copy this file to .env and fill in your values

# Groq API Key (Free API for Llama3)
# Get yours at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL Database URL
# Format: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leadforge

# Ollama Base URL (Local fallback LLM)
# Ollama Base URL (Local fallback LLM)
OLLAMA_BASE_URL=http://localhost:11434

# Proxy Arrays (Optional: Use exactly like this: http://user:pass@ip:port,http...)
PROXY_URLS=

# Automated SMTP Sender Settings
# Set SIMULATE_EMAIL=False to actually dispatch real emails
SIMULATE_EMAIL=True
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
